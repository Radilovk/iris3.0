# ─── Iris Iridology Analyzer — Environment Variables ────────────────────────
# Copy this file to .env (never commit .env to source control).
# Cloudflare Worker: set secrets via `wrangler secret put <KEY>`.
# Flask app (app.py): export these vars before running.

# ─── AI Provider Selection ───────────────────────────────────────────────────
# Choose the active AI provider: "gemini" | "openai" | "openai-compatible"
AI_PROVIDER=gemini

# ─── AI Model ────────────────────────────────────────────────────────────────
# Must support vision (image input).
#
# Gemini models:
#   gemini-2.5-pro-preview-05-06    Most capable; preview
#   gemini-2.5-flash-preview-04-17  Best quality Flash; preview
#   gemini-2.5-flash-latest         Rolling alias — latest 2.5 Flash
#   gemini-2.0-flash                Stable, fast — RECOMMENDED DEFAULT
#   gemini-2.0-flash-lite           Lightweight variant
#   gemini-1.5-pro-latest           Stable 1.5 Pro fallback
#   gemini-1.5-flash-latest         Fast 1.5 Flash
#
# OpenAI models:
#   gpt-4.1                         Latest flagship (2025) — RECOMMENDED
#   gpt-4o                          Premium multimodal flagship
#   gpt-4o-mini                     Cost-effective multimodal
#   gpt-4-turbo                     Previous flagship with vision
#   o4-mini                         Fast reasoning with vision (2025)
#
AI_MODEL=gemini-2.0-flash

# ─── API Base URLs ───────────────────────────────────────────────────────────
# Gemini REST API endpoint (used when AI_PROVIDER=gemini)
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI-compatible API endpoint (used when AI_PROVIDER=openai or openai-compatible)
AI_BASE_URL=https://api.openai.com/v1

# Alternative base URL examples:
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/<deploy>/v1
#   Local Ollama:  http://localhost:11434/v1
#   LM Studio:     http://localhost:1234/v1

# ─── API Keys (secrets — never commit real values) ───────────────────────────
# Gemini:  obtain at https://aistudio.google.com/app/apikey
# OpenAI:  obtain at https://platform.openai.com/api-keys
AI_API_KEY=your_api_key_here

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# Protects all /admin/* routes. Leave empty to disable auth (dev only).
ADMIN_SECRET=your_admin_secret_here

# ─── Flask App (app.py) ──────────────────────────────────────────────────────
# URL of the deployed Cloudflare Worker (optional — enables worker AI pipeline)
IRIS_WORKER_URL=https://iris-analyzer.<your-subdomain>.workers.dev

# Timeout in seconds for worker requests (default: 120)
IRIS_WORKER_TIMEOUT=120

# Flask secret key (used for session signing)
SECRET_KEY=change_me_to_a_random_secret
